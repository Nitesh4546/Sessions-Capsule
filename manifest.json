{
  "manifest_version": 3,
  "name": "Tab Session Manager",
  "version": "1.0.0",
  "description": "Save, organize, and restore your tab sessions directly from the browser sidebar.",
  "permissions": [
    "tabs",
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Tab Session Manager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
